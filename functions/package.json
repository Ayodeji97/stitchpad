{
  "name": "functions",
  "description": "Cloud Functions for StitchPad",
  "private": true,
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "scripts": {
    "build": "tsc",
    "lint": "eslint --ext .js,.ts src/",
    "test": "jest",
    "test:rules": "firebase emulators:exec --only firestore --project=demo-stitchpad \"jest --config jest.rules.config.js\"",
    "deploy": "npm run build && firebase deploy --only functions:onAuthUserDeleted,functions:smartDraftMessage,functions:reconcileCustomerSlots,functions:sendVerificationEmail,functions:sendPasswordResetEmail,functions:processPasswordResetEmail,functions:dailyDigest,functions:debugSendMyDigest,functions:initializeSubscriptionCheckout,functions:paystackWebhook,functions:expirePrepaidSubscriptions,functions:prepaidSubscriptionReminder"
  },
  "dependencies": {
    "@google/genai": "^2.3.0",
    "firebase-admin": "^12.7.0",
    "firebase-functions": "^6.0.1"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/jest": "^29.5.13",
    "@types/node": "^20.16.0",
    "@typescript-eslint/eslint-plugin": "^8.8.0",
    "@typescript-eslint/parser": "^8.8.0",
    "eslint": "^8.57.0",
    "firebase": "^12.14.0",
    "firebase-functions-test": "^3.3.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.0"
  }
}
