# Template for functions/.env, which is gitignored because it sits alongside real
# secrets. The values below are public URLs, not credentials — copy this file to
# .env in any fresh clone or worktree before deploying, or checkout redirects
# silently fall back to Paystack's default success page.
#
# Secrets (PAYSTACK_SECRET_KEY, RESEND_API_KEY) are NOT set here — they live in
# Firebase Secret Manager and bind at deploy time:
#   firebase functions:secrets:set PAYSTACK_SECRET_KEY

# Where Paystack sends the payer after a successful gift purchase. A marketing-site
# page, not a deep link: the gifter is often on desktop and may not have the app.
PAYSTACK_GIFT_CALLBACK_URL=https://getstitchpad.com/gift/success

# Where Paystack sends the payer after a successful subscription purchase. An https
# App Link / Universal Link, so Android reopens the app on the Upgrade screen
# (assetlinks.json is served from that host; see the manifest's autoVerify filter).
# If interception fails, the URL serves a fallback page with an "open the app"
# button. Either way the tier is granted by the webhook, not by this redirect.
PAYSTACK_CALLBACK_URL=https://link.getstitchpad.com/upgrade
