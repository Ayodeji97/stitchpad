<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <!--
        Dark-mode splash. Same style names, same attribute structure as
        values/styles.xml — the system resolves @color/colorSplashBg to the
        inkDark override defined in values-night/colors.xml, so the system
        splash, post-splash window, and Compose splash all end up on inkDark
        in dark mode. The launcher foreground vector also adapts via its
        @color/colorBrand* references.
    -->

    <style name="Theme.StitchPad" parent="@android:style/Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/colorSplashBg</item>
    </style>

    <style name="Theme.StitchPad.SplashScreen" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/colorSplashBg</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="android:windowSplashScreenBackground" tools:targetApi="s">@color/colorSplashBg</item>
        <item name="android:windowSplashScreenAnimatedIcon" tools:targetApi="s">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.StitchPad</item>
        <item name="android:windowBackground">@color/colorSplashBg</item>
    </style>

</resources>
