<?xml version="1.0" encoding="utf-8"?>
<!--
  Pre-Android-12 (API < 31) backup rules. Applied via android:fullBackupContent.

  Excluded from Auto-Backup:
  - stitchpad_prefs (SharedPreferences backing OnboardingPreferences) — so a
    reinstall on the same Google account starts with a clean onboarding state.
  - files/offline_uploads — pending offline customer/style/order/logo images
    (OfflinePhotoStore); customer PII / business assets must not sync to a
    user's personal cloud backup.
-->
<full-backup-content>
    <exclude domain="sharedpref" path="stitchpad_prefs.xml" />
    <exclude domain="file" path="offline_uploads" />
</full-backup-content>
