<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+) data extraction rules. Applied via
  android:dataExtractionRules. Supersedes backup_rules.xml on API 31+.

  Excluded from BOTH cloud backup (Google Drive) AND device-to-device transfer
  (Pixel-to-Pixel restore, Samsung Smart Switch, etc.):
  - stitchpad_prefs.xml: the onboarding-seen flag, so the value-prop tour
    reappears on every truly fresh install.
  - files/offline_uploads: pending offline customer/style/order/logo images
    (see OfflinePhotoStore). These are customer PII / business assets queued
    for upload and must not sync to a user's personal cloud backup.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="stitchpad_prefs.xml" />
        <exclude domain="file" path="offline_uploads" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="stitchpad_prefs.xml" />
        <exclude domain="file" path="offline_uploads" />
    </device-transfer>
</data-extraction-rules>
