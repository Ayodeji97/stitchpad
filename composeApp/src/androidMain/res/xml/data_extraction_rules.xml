<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ (API 31+) data extraction rules. Applied via
  android:dataExtractionRules. Supersedes backup_rules.xml on API 31+.

  Two separate sections so we can opt the SharedPreferences file out of
  BOTH cloud backup (Google Drive) AND device-to-device transfer
  (Pixel-to-Pixel restore, Samsung Smart Switch, etc.). Without device
  transfer exclusion the onboarding-seen flag follows the user across
  phones — fine in the abstract, but contradicts our intent that the
  value-prop tour reappear on every truly fresh install.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="sharedpref" path="stitchpad_prefs.xml" />
    </cloud-backup>
    <device-transfer>
        <exclude domain="sharedpref" path="stitchpad_prefs.xml" />
    </device-transfer>
</data-extraction-rules>
