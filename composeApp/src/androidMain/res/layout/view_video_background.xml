<?xml version="1.0" encoding="utf-8"?>
<!--
  Background video surface for the welcome screen. A TextureView surface (not the
  default SurfaceView) so it composites cleanly inside Compose: the poster image
  underneath shows until the first frame, and the scrim + CTA buttons drawn on top
  render correctly. resize_mode="zoom" centre-crops the clip to fill.
-->
<androidx.media3.ui.PlayerView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/transparent"
    app:surface_type="texture_view"
    app:resize_mode="zoom"
    app:use_controller="false"
    app:shutter_background_color="@android:color/transparent" />
