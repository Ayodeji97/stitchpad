# Gradle
.gradle/
build/
!src/**/build/
!gradle/wrapper/gradle-wrapper.jar

# IDE
.idea/
*.iml
.kotlin/

# macOS
.DS_Store

# Android
local.properties
captures/
.externalNativeBuild/
.cxx/

# iOS / Xcode
xcuserdata/
*.xcodeproj/*
!*.xcodeproj/project.pbxproj
!*.xcodeproj/xcshareddata/
!*.xcodeproj/project.xcworkspace/
!*.xcworkspace/contents.xcworkspacedata
**/xcshareddata/WorkspaceSettings.xcsettings
Pods/
*.xcworkspace
!**/*.xcodeproj/project.xcworkspace/
!**/*.xcodeproj/project.xcworkspace/xcshareddata/
!**/*.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/
!**/*.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/Package.resolved

# Secrets — NEVER commit these
**/google-services.json
**/GoogleService-Info.plist

# Node (if any tooling uses it)
node_modules/

# Superpowers brainstorm mockups
.superpowers/

# Claude Code local tooling (settings, caches, session locks)
# Allow sharing slash commands but exclude everything else.
.claude/*
!.claude/commands/

# Debug menu test creds — local only, never committed
composeApp/debug-test-accounts.properties

# Release signing — keystore + passwords, never committed
composeApp/release-signing.properties
*.jks

# Fastlane secrets and runtime artifacts
fastlane/.env
fastlane/report.xml
fastlane/Preview.html
fastlane/test_output/
fastlane/README.md

# Agent-specific local tooling (Codex, etc.) — not part of the repo
AGENTS.md
.agents/
.claire/

# Misc
*.log
*.tmp
