rules_version = '2';

// StitchPad Firestore security rules — V1.0 freemium.
//
// Threat model: a signed-in malicious client wielding a Firestore SDK can bypass
// our Kotlin/Compose UI gates and write directly to their own docs. These rules
// stop the high-value bypasses:
//   1. Granting themselves a paid tier (subscriptionTier flip).
//   2. Re-filling their welcome bonus (bonusCoins refill).
//   3. Replaying the welcome window (welcomeBonusAppliedAt rewind).
//   4. Editing the server's Smart-usage truth (usage/smart_drafts.bonusBalance / count).
//
// What we deliberately DO NOT enforce in rules (V1.0):
//   - **Customer cap on create.** Client UI gates the +Customer button against the
//     active count; reconcileSlots Cloud Function reconciles excess back to locked
//     on the next foreground. A determined bypasser can briefly seed extra active
//     customers; the cap re-asserts on next reconcile. Rule-level enforcement
//     would require a per-create `get()` lookup of the user doc (expensive) and
//     duplicating the welcome-window math in rules — deferred until we ship a
//     server-side createCustomer Cloud Function.
//   - **Customer slotState locking.** The SwapSheet flow batches two updates from
//     the client (promote + demote). Locking slotState would break it. Deferred
//     until swap migrates to a Cloud Function (tracked as a V1.0 follow-up).
//   - **Tier flips via debug menu.** Setting tier=pro from the deployed app's
//     debug menu hits these rules and fails. Use Firebase Console > Firestore to
//     manually flip a tester account's tier when needed. Production has no
//     legitimate client-side tier-write path until a Paystack webhook function
//     lands.

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ────────────────────────────────────────────────────────────
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // True iff the incoming update keeps `field` at its existing value (i.e. the
    // client did not attempt to change it). Compatible with merge-true updates
    // where `request.resource.data` is the full merged result. NOTE: this returns
    // true when the field is absent from the update, so it does NOT block
    // FieldValue.delete() — only use it for fields where deletion is harmless.
    function fieldUnchanged(field) {
      return !(field in request.resource.data) ||
             request.resource.data[field] == resource.data[field];
    }

    // A server-only field. Once present it must stay present and equal — which
    // blocks edits AND deletes (a delete drops the field from request.resource.data)
    // — and a client may never add it via update. Used for the subscription fields,
    // all set by the Paystack webhook, the Apple IAP functions (verifyAppleTransaction
    // / appStoreServerNotifications), or the createUserProfile seed — all Admin SDK,
    // which bypasses rules: subscriptionTier, subscriptionStatus, subscriptionEndsAt,
    // subscriptionRenews, plus the Apple provenance fields subscriptionSource,
    // appleOriginalTransactionId, appleProductId. This closes two holes: deleting subscriptionEndsAt /
    // subscriptionRenews to dodge the expirePrepaidSubscriptions query (and keep
    // paid access), and deleting subscriptionTier / subscriptionStatus to corrupt
    // billing state. NOT used for welcomeBonusAppliedAt / bonusCoins: blocking adds
    // there is unnecessary (deleting them only downgrades the user) and those use
    // fieldUnchanged to avoid any interaction with the welcome-bonus create rule.
    function serverOnlyField(field) {
      return (field in resource.data)
        ? (field in request.resource.data
           && request.resource.data[field] == resource.data[field])
        : !(field in request.resource.data);
    }

    // ── /users/{uid} ───────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isOwner(uid);

      // Client-side delete is denied to prevent welcome-window replay.
      // Without this, a signed-in user using the Firestore SDK directly
      // could delete their own user doc (customers subcollection is NOT
      // cascade-deleted by Firestore) and then immediately recreate it
      // under `allow create` rules with a fresh `welcomeBonusAppliedAt
      // == request.time` and `bonusCoins == 30` — restoring First Month
      // status + bonus coins indefinitely while keeping all their data.
      //
      // Legitimate account deletion goes through Auth.delete() →
      // onAuthUserDeleted Cloud Function, which uses the Admin SDK
      // (bypasses rules) to clean up users/{uid} + subcollections.
      allow delete: if false;

      // Initial profile create: enforce safe defaults for every financially
      // meaningful field. Matches `FirebaseUserRepository.buildInitialUserDoc()`.
      // Anything the client invents beyond these caps gets rejected.
      //
      // welcomeBonusAppliedAt must equal request.time (the server-resolved
      // value that FieldValue.serverTimestamp materializes into). Without this
      // a malicious client could set it to a future timestamp at signup and
      // permanently extend their First Month welcome window.
      allow create: if isOwner(uid)
        && (!('subscriptionTier' in request.resource.data) ||
            request.resource.data.subscriptionTier == 'free')
        && (!('subscriptionStatus' in request.resource.data) ||
            request.resource.data.subscriptionStatus == 'active')
        && (!('subscriptionRenews' in request.resource.data) ||
            request.resource.data.subscriptionRenews == false)
        && (!('customerCount' in request.resource.data) ||
            request.resource.data.customerCount == 0)
        && (!('bonusCoins' in request.resource.data) ||
            request.resource.data.bonusCoins == 30)
        && (!('welcomeBonusAppliedAt' in request.resource.data) ||
            request.resource.data.welcomeBonusAppliedAt == request.time)
        // subscriptionEndsAt is server-owned (set only by the Paystack webhook /
        // Apple IAP / gift functions via the Admin SDK). A client must never plant
        // it at creation, or it could ride a far-future date by buying a single period.
        && (!('subscriptionEndsAt' in request.resource.data))
        // Apple provenance fields are likewise server-owned and must be absent at
        // creation — a client could otherwise self-mark as an Apple subscriber.
        && (!('subscriptionSource' in request.resource.data))
        && (!('appleOriginalTransactionId' in request.resource.data))
        && (!('appleProductId' in request.resource.data))
        // subscriptionFallbackTier/EndsAt are the queued lower-tier segment from a
        // mismatched-tier gift — server-owned, never planted at creation.
        && (!('subscriptionFallbackTier' in request.resource.data))
        && (!('subscriptionFallbackEndsAt' in request.resource.data))
        // giftLinkToken is the public token behind a tailor's "Gift me" link,
        // minted only by createGiftLink (Admin SDK). A client-planted token could
        // collide with the giftLinkTokens reverse index and hijack another tailor's
        // incoming gifts, so it must never be set at creation.
        && (!('giftLinkToken' in request.resource.data))
        // referredBy is the marketer id credited for this signup, stamped only by
        // recordReferralAttribution (Admin SDK) after it validates the referral
        // code. A client-planted value would let a user self-attribute to any
        // marketer (or itself), inflating payouts — so it must never be set at
        // creation.
        && (!('referredBy' in request.resource.data));

      // Profile updates: user can edit display fields freely, but cannot touch
      // the financially meaningful fields. Server (admin SDK) bypasses these
      // rules so Cloud Functions and Firebase Console edits still work.
      allow update: if isOwner(uid)
        && serverOnlyField('subscriptionTier')
        && serverOnlyField('subscriptionStatus')
        && serverOnlyField('subscriptionEndsAt')
        && serverOnlyField('subscriptionRenews')
        && serverOnlyField('subscriptionSource')
        && serverOnlyField('appleOriginalTransactionId')
        && serverOnlyField('appleProductId')
        && serverOnlyField('subscriptionFallbackTier')
        && serverOnlyField('subscriptionFallbackEndsAt')
        && serverOnlyField('giftLinkToken')
        && serverOnlyField('referredBy')
        && fieldUnchanged('welcomeBonusAppliedAt')
        && fieldUnchanged('bonusCoins')
        && fieldUnchanged('customerCount');

      // ── Custom measurement fields ────────────────────────────────────────
      // PTSP-12 — Per-tailor custom field definitions. Soft-archive only;
      // no hard-delete (delete is explicitly denied so past measurements'
      // UUID-to-label mappings stay intact). Client-side gate on tier;
      // server-side feature gate is deferred (see custom-measurements
      // design doc §7).
      match /customMeasurementFields/{fieldId} {
        allow read, create, update: if isOwner(uid);
        // delete is intentionally omitted — soft-archive only.
      }

      // ── Customer subcollection ───────────────────────────────────────────
      // slotState/lockedAt stay client-writable in V1.0 because the SwapSheet
      // mutates them directly via Firestore batch. See top-level comment.
      match /customers/{customerId} {
        allow read, create, update, delete: if isOwner(uid);

        match /measurements/{measurementId} {
          allow read, write: if isOwner(uid);
        }

        match /styles/{styleId} {
          allow read, write: if isOwner(uid);
        }

        // Named style collections (folders) within a customer's closet, each
        // with its own styles subcollection.
        match /styleFolders/{folderId} {
          allow read, write: if isOwner(uid);

          match /styles/{styleId} {
            allow read, write: if isOwner(uid);
          }
        }
      }

      // ── Orders subcollection ─────────────────────────────────────────────
      match /orders/{orderId} {
        allow read, write: if isOwner(uid);
      }

      // ── Inspiration style gallery ───────────────────────────────────────
      // Top-level styles that are not tied to a customer closet.
      match /inspiration/{styleId} {
        allow read, write: if isOwner(uid);
      }

      // Named style collections (folders) at the Inspiration level, each with
      // its own styles subcollection.
      match /inspirationFolders/{folderId} {
        allow read, write: if isOwner(uid);

        match /styles/{styleId} {
          allow read, write: if isOwner(uid);
        }
      }

      // ── Notifications inbox subcollection ───────────────────────────────
      // Server (Admin SDK) creates docs via create-if-absent; client reads
      // them and marks isRead. No client create (deterministic ids would
      // resurrect a dismissed-but-still-open notification on the next scan)
      // and no client delete in V1.
      match /notifications/{notificationId} {
        allow read: if isOwner(uid);
        allow update: if isOwner(uid)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead'])
          && request.resource.data.isRead is bool;
        allow create, delete: if false;
      }

      // ── Push notification tokens subcollection ──────────────────────
      // Owner-managed: the device registers/refreshes/removes its own token.
      match /notificationTokens/{token} {
        allow read, create, update, delete: if isOwner(uid);
      }

      // ── Custom garment types subcollection ───────────────────────────────
      // Stores tailor-defined garment names (e.g. "Iro/Buba"). Client reads
      // these in the garment picker and writes on upsert / touch. No
      // financially meaningful fields — full read/write for the owner.
      match /customGarmentTypes/{docId} {
        allow read, write: if isOwner(uid);
      }

      // ── Goals subcollection ──────────────────────────────────────────────
      match /goals/{goalId} {
        allow read, write: if isOwner(uid);
      }

      // ── Smart usage subcollection — server-only writes ───────────────────
      // The client reads `users/{uid}/usage/smart_drafts.bonusBalance` and
      // `.count` to keep PlanCard in sync (see SmartUsageDocSource), but the
      // server's draftMessage Cloud Function is the only writer — it decrements
      // bonusBalance per draft and increments count per monthly call.
      //
      // A successful client write here would let a user reset their AI quota
      // mid-month. Hard deny.
      match /usage/{usageDoc} {
        allow read: if isOwner(uid);
        allow write: if false;
      }

      // ── Billing transactions — server-only writes ───────────────────────
      // The app can observe checkout/payment status for its own account, but
      // transaction creation, Paystack references, paid markers, and entitlement
      // updates must come only from Cloud Functions using the Admin SDK.
      match /billingTransactions/{transactionId} {
        allow read: if isOwner(uid);
        allow write: if false;
      }
    }

    // ── /appleSubscriptions/{originalTransactionId} — server-only index ────
    // Reverse index mapping an Apple subscription's originalTransactionId to the
    // Firebase uid that owns it. Written by the Apple IAP functions (Admin SDK)
    // so an App Store Server Notification can find its user, and so a restore on
    // a second account can be refused. No client may read or write it — the uid
    // ownership map must not be enumerable or forgeable from a device.
    match /appleSubscriptions/{originalTransactionId} {
      allow read, write: if false;
    }

    // ── /gifts/{giftId} — Admin-SDK only ───────────────────────────────────
    // Gift docs hold payment state and the bearer claim code (which IS the doc id
    // for public gifts). A client must never read a code (bearer credential) nor
    // write payment/claim state. Redemption goes through the redeemGift Cloud
    // Function; public gift profiles through getPublicGiftProfile. Hard deny.
    match /gifts/{giftId} {
      allow read, write: if false;
    }

    // ── /giftLinkTokens/{token} — Admin-SDK only ───────────────────────────
    // Reverse index token -> uid, read only by getPublicGiftProfile (Admin SDK) so
    // the users collection stays owner-read-only. Minted by createGiftLink. Hard deny.
    match /giftLinkTokens/{token} {
      allow read, write: if false;
    }

    // ── Referral / marketing-attribution — all Admin-SDK only ─────────────
    // A referral system pays real money to marketers per genuinely-active
    // referred user, so every collection here is server-owned and hard-denied
    // to clients (mirrors the gifts / giftLinkTokens bearer-credential model):
    //
    //   marketers/{id}          — the referrer entity (affiliate or, later, a
    //                             user). Holds payout rate + bank details. A
    //                             client read would leak other marketers' payout
    //                             terms; a write could self-enroll or raise a rate.
    //   referralCodes/{code}    — reverse index code -> marketerId (the code IS
    //                             the doc id). A client write could hijack a code.
    //   referrals/{referredUid} — per-referred-user milestone + payout state,
    //                             computed by recordReferralAttribution +
    //                             reconcileReferrals. A client write could self-
    //                             mark as qualified and mint a payout.
    //   referralDevices/{hash}  — device-dedupe reverse index; enumerating or
    //                             forging it would defeat reinstall fraud checks.
    match /marketers/{marketerId} {
      allow read, write: if false;
    }
    match /referralCodes/{code} {
      allow read, write: if false;
    }
    match /referrals/{referredUid} {
      allow read, write: if false;
    }
    match /referralDevices/{deviceHash} {
      allow read, write: if false;
    }

    // ── Global remote app config (community link, future feature flags) ──
    // Read-only for any signed-in user; only console/admin writes.
    match /config/{configDoc} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // ── /account_deletion_feedback/{docId} — analytics-only writes ─────────
    // FirestoreDeletionFeedbackRepository writes anonymous-shaped feedback
    // (reason, additionalNotes, plan, daysActive, platform, appVersion,
    // locale, createdAtEpochMs) here right before the user deletes their
    // account. Any authenticated user can create; nobody can read, update,
    // or delete from a client. Admin SDK / Firebase Console bypass rules
    // for analytics consumption.
    //
    // Without this rule, the delete-account flow silently drops feedback
    // (rules default to deny), masking signal we need from churn.
    match /account_deletion_feedback/{docId} {
      allow create: if request.auth != null;
    }
  }
}
