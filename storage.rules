rules_version = '2';

// StitchPad Cloud Storage security rules.
//
// Every object the app writes lives under users/{uid}/... — brand logos,
// per-order fabric/style photos, customer style folders, and inspiration
// images. Restrict each object to its owner so one tailor can never read,
// overwrite, or delete another tailor's photos (customer PII + design IP).
//
// Notes:
// - Intentionally-shared assets surfaced via a download URL (getDownloadUrl,
//   e.g. the email/gift-profile logo) keep working — Firebase download tokens
//   grant access independently of these rules by design.
// - Anything outside users/{uid}/ has no match and is denied by default.
// - Content-type / size validation on write is deliberately omitted here to
//   avoid breaking existing uploads; add it as hardening once verified against
//   the client's upload metadata.
service firebase.storage {
  match /b/{bucket}/o {
    match /users/{uid}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    // Shared, read-only app content: the how-to tutorial videos at
    // tutorials/{topic}.mp4. Same clips for every tailor, no PII. The client
    // calls getDownloadUrl() on these paths (TutorialMediaResolver), which
    // itself needs read permission — without this rule the path matches nothing
    // and is denied by default (403), so tutorials never play. Reads are gated
    // to signed-in users (tutorials are only reachable inside the app); writes
    // stay closed — clips are uploaded out-of-band (console/CI), never by the client.
    match /tutorials/{allPaths=**} {
      allow read: if request.auth != null;
    }
  }
}
